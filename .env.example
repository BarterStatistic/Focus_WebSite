# Copia este archivo como .env y rellena los valores

# Puerto del servidor
PORT=3000

# Secreto para firmar los JWT (cámbialo por una cadena larga y aleatoria)
JWT_SECRET=focus_super_secret_key_2024

# Google OAuth2 (obtén estas credenciales en console.cloud.google.com)
GOOGLE_CLIENT_ID=tu_google_client_id_aqui
GOOGLE_CLIENT_SECRET=tu_google_client_secret_aqui
GOOGLE_REDIRECT_URI=http://localhost:3000/api/calendar/callback

# URL base de la app (para producción cambia a tu dominio)
APP_URL=http://localhost:3000
